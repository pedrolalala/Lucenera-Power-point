# ==================== SHAREPOINT MICROSOFT GRAPH API ====================
# Credenciais do Azure AD App Registration
# ⚠️ NUNCA coloque credenciais reais neste arquivo de exemplo!
SHAREPOINT_CLIENT_ID=seu-client-id-azure-aqui
SHAREPOINT_TENANT_ID=seu-tenant-id-aqui
SHAREPOINT_CLIENT_SECRET=seu-client-secret-aqui
SHAREPOINT_DRIVE_NAME=LUCENERA PROJETOS

# ==================== CONFIGURAÇÕES DA APLICAÇÃO ====================
# Porta do servidor Flask (deve coincidir com cloudflared)
PORT=5001

# Pasta onde XMLs/PDFs são salvos e PPTs são gerados
UPLOAD_FOLDER=C:\Users\pedro\OneDrive\Desktop\lucenera

# Pasta do projeto (onde estão os scripts Python)
SCRIPT_DIR=C:\script python\script python power point

# Caminho para o Excel master com dados dos produtos
EXCEL_MASTER=C:\Users\pedro\OneDrive\Desktop\lucenera\master_produtos.xlsx

# Caminho para o Python do ambiente virtual
PYTHON_VENV=C:\script python\script python power point\.venv\Scripts\python.exe

# ==================== CONFIGURAÇÕES DE PRODUÇÃO ====================
# URL do site em produção (sem barra no final)
SITE_URL=https://sistema.apilucenera.site

# Modo de execução (development ou production)
FLASK_ENV=production

# ==================== NOTAS ====================
# 1. Copie este arquivo para .env na raiz do projeto
# 2. Preencha os valores reais (sem aspas)
# 3. Nunca compartilhe o .env com credenciais reais
# 4. O .env está no .gitignore (não será commitado)
